# Copy to .env and fill in. .env is gitignored — never commit real values.
# The pipeline (ingest.py) uses the SERVICE/secret key, server-side only.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=YOUR-SERVICE-KEY

# Optional: your firm's annual turnover in Lakhs (drives the fit score).
TURNOVER_LAKHS=500

# Optional: enables LLM-powered requirement/document extraction in the evaluator.
# Without it, the evaluator uses a deterministic keyword extractor (still works).
ANTHROPIC_API_KEY=

# Optional: controls the CG eProcurement Playwright scraper (scrapers/cg_eproc.py).
# CG_EPROC_MAX_ROWS=500  # cap on rows harvested (default 500, 0 = no limit)
# CG_EPROC_HEADLESS=1    # set to 0 to watch the browser during development

# Optional: controls the UP eTender Playwright scraper (scrapers/up_etender.py).
# UP_ETENDER_HEADLESS=1  # set to 0 to watch the browser during development

# Optional: controls the CPPP state tender scraper (scrapers/cppp_state.py).
# CPPP_STATE=Uttar Pradesh  # state name to filter (default: Uttar Pradesh)
# CPPP_MAX_PAGES=100        # listing pages to scan, 10 rows each (default: 100)
