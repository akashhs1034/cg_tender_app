# Opporta scraper secrets — copy to ~/opporta.env on the VM and fill in.
# These are the SAME values you already set as GitHub Actions secrets.
# (In GitHub: repo → Settings → Secrets and variables → Actions.)
#
#   cp opporta.env.example ~/opporta.env
#   nano ~/opporta.env      # paste real values
#   chmod 600 ~/opporta.env

# --- Required ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=
GEMINI_API_KEY=

# --- Optional (email alerts + links; leave blank to skip) ---
RESEND_API_KEY=
FROM_EMAIL=
APP_URL=

# --- Optional tuning (safe defaults if omitted) ---
# GEM_MAX_PAGES=10
# CPPP_MAX_PAGES=100
# CPPP_CENTRAL_MAX_PAGES=80
