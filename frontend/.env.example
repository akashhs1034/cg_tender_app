# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Google Gemini — enables AI-written bid drafts (optional).
# Without it, the bid drafter falls back to a template. Set on Vercel too.
GEMINI_API_KEY=your-gemini-api-key
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Supabase service role — server-only. Enables caching AI results back onto
# tenders/jobs so Gemini is billed once per item, not per click. Optional:
# without it, AI still works but results are not cached. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
