# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Google Gemini — enables AI-written bid drafts (optional).
# Without it, the bid drafter falls back to a template. Set on Vercel too.
GEMINI_API_KEY=your-gemini-api-key
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
