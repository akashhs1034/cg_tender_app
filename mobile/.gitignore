# Flutter / Dart — ignore build artifacts, COMMIT the platform folders
# (android/, web/) so the manifest, permissions, signing config and icons are
# version-controlled for the Play Store build.
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/

# Android build/local artifacts (but keep android/ itself)
android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/
**/android/local.properties
**/android/.cxx/

# Signing — NEVER commit these
**/key.properties
*.jks
*.keystore

# IDE
.idea/
.vscode/
*.iml
